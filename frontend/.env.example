# URL бэкенд-сервера (серверная переменная, используется в next.config.ts rewrite)
API_URL=http://localhost:8000

# Публичный URL API для клиентских запросов.
# ВАЖНО: НЕ указывайте http://localhost:8000 — это создаст cross-origin запросы
# и сломает передачу Authorization header + cookie.
# Используйте /api — Next.js rewrite проксирует запросы на API_URL.
NEXT_PUBLIC_API_URL=/api

# Окружение
NODE_ENV=development
